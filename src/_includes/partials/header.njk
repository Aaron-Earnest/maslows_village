<header>
    <h1>{{ site.name }}</h1>
    <nav>
        <ul>
            {%- for entry in collections.all | eleventyNavigation -%}
            <li{% if entry.url == page.url %} class="active"{% endif %}>
                <a href="{{ entry.url }}">{{ entry.title }}</a>
            </li>
            {%- endfor -%}
        </ul>
    </nav>
</header>